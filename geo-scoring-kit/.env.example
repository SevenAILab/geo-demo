# === GEO 独立业务服务 ===
GEO_PORT=18790
GEO_HOST=127.0.0.1
GEO_CONFIG_PATH=../config/openclaw.geo-demo.json
OPENCLAW_BASE_URL=http://127.0.0.1:18789
# 只放 GEO 后端，禁止放入前端构建变量
OPENCLAW_SERVICE_TOKEN=replace-with-openclaw-service-token

# === 大模型（实测层 probe / cross-model-validate 需要）===
# Claude（llm-clients/claude-client.mjs）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_WIRE_API=

# OpenAI / DeepSeek（llm-clients/openai-client.mjs）
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Qwen / 通义（llm-clients/qwen-client.mjs）
DASHSCOPE_API_KEY=

# === 联网搜证（web-search.mjs，找 source_tier 证据用）===
EXA_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=

# === LLM 重试策略（可选）===
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_DELAY_MS=1000
